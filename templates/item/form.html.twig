{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">
            <i class="bi bi-{{ item is defined and item ? 'pencil-square' : 'plus-circle' }} me-2"></i>{{ title }}
        </h4>
        <a href="{{ path('item_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Geri Dön
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-input-cursor-text me-2"></i>İtem Bilgileri
                </div>
                <div class="card-body p-4">
                    {{ form_start(form) }}

                    <!-- İsim -->
                    <div class="mb-4">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <hr>

                    {{ form_widget(form.submit) }}

                    {{ form_end(form) }}
                </div>
            </div>

            {% if item is defined and item %}
                <div class="card mt-3">
                    <div class="card-body">
                        <div class="text-muted small">
                            <i class="bi bi-hash me-1"></i>ID: {{ item.id }}
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
